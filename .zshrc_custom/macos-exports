# Homebrew: prefer Apple Silicon Homebrew even if path_helper or inherited PATH added /usr/local first.
path=(${path:#/opt/homebrew/bin})
path=(${path:#/opt/homebrew/sbin})
[[ -d "/opt/homebrew/bin" ]] && path=("/opt/homebrew/bin" $path)
[[ -d "/opt/homebrew/sbin" ]] && path=("/opt/homebrew/sbin" $path)

# Flutter
[[ -d "$HOME/.rbenv/bin" ]] && path=("$HOME/.rbenv/bin" $path)
[[ -d "$HOME/flutter/bin" ]] && path=("$HOME/flutter/bin" $path)
path=(${path:#${USER}/flutter/bin})

# Android
export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH="$PATH:$ANDROID_HOME/emulator:$ANDROID_HOME/tools:$ANDROID_HOME/tools/bin:$ANDROID_HOME/platform-tools"

# Docker
export PATH="$PATH:/Applications/Docker.app/Contents/Resources/bin/"

# Codex
export PATH="$PATH:/Applications/Codex.app/Contents/Resources"
export PATH="$PATH:$HOME/.codeium/windsurf/bin:$HOME/.lmstudio/bin"

# Export React Editor
export REACT_EDITOR=code

# 1Password SSH Agent
export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock

# Java Development Kit
export JAVA_HOME=$(/usr/libexec/java_home -v 22)
export PATH="$JAVA_HOME/bin:$PATH"

# Projects
export PLATO_ENV_SOURCE_DIR="$HOME/Developer/plato-ai"
