#!/usr/bin/env zsh
set -u

redact_home() {
  local line
  while IFS= read -r line || [[ -n "$line" ]]; do
    print -r -- "${line//$HOME/~}"
  done
}

status() {
  printf "%-34s %s\n" "$1" "$2"
}

exists_file() {
  [[ -e "$1" ]] && status "$2" "present" || status "$2" "missing"
}

command_version() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then
    status "$cmd" "$(command -v "$cmd" | redact_home)"
  else
    status "$cmd" "missing"
  fi
}

env_present() {
  local name="$1"
  if [[ -n "${(P)name:-}" ]]; then
    status "env:$name" "set"
  else
    status "env:$name" "missing"
  fi
}

command_ok() {
  local label="$1"
  shift

  if "$@" >/dev/null 2>&1; then
    status "$label" "ok"
  else
    status "$label" "unavailable"
  fi
}

discover_env_names() {
  local -a files=(
    "$HOME/.zshenv.local"
  )
  local file

  for file in "${files[@]}"; do
    [[ -r "$file" ]] || continue
    sed -nE \
      -e 's/^[[:space:]]*(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=.*/\2/p' \
      -e 's/^[[:space:]]*export[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*$/\1/p' \
      "$file"
  done | sort -u
}

printf "1Password developer preflight\n"
status "host" "${AGENT_HOST_ALIAS:-$(hostname -s)}"
status "macOS" "$(sw_vers -productVersion 2>/dev/null || printf unknown)"
if [[ -n "${SSH_CONNECTION:-}${SSH_CLIENT:-}" ]]; then
  status "inbound SSH session" "yes"
else
  status "inbound SSH session" "no"
fi

command_version op
if command -v op >/dev/null 2>&1; then
  status "op version" "$(op --version 2>/dev/null || printf unknown)"
  command_ok "op account list" op account list
  command_ok "op plugin list" op plugin list
fi

exists_file "/Applications/1Password.app" "1Password.app"
exists_file "/Applications/1Password.app/Contents/MacOS/onepassword-mcp" "onepassword-mcp"

if command -v codex >/dev/null 2>&1; then
  if codex mcp list 2>/dev/null | awk 'BEGIN{found=0} /^1password[[:space:]]/ {found=1} END{exit found ? 0 : 1}'; then
    status "codex mcp:1password" "configured"
  else
    status "codex mcp:1password" "missing"
  fi
else
  status "codex" "missing"
fi

if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
  status "SSH_AUTH_SOCK" "$(printf "%s" "$SSH_AUTH_SOCK" | redact_home)"
else
  status "SSH_AUTH_SOCK" "missing"
fi

if ssh-add -l >/dev/null 2>&1; then
  status "ssh-add key count" "$(ssh-add -l 2>/dev/null | wc -l | tr -d ' ')"
else
  status "ssh-add" "unavailable"
fi

exists_file "$HOME/.config/1Password/ssh/agent.toml" "agent.toml"
if [[ -r "$HOME/.config/1Password/ssh/agent.toml" ]]; then
  status "agent.toml entries" "$(grep -c '^\[\[ssh-keys\]\]' "$HOME/.config/1Password/ssh/agent.toml")"
fi

exists_file "$HOME/.config/op/plugins.sh" "op plugins.sh"
if [[ -r "$HOME/.config/op/plugins.sh" ]]; then
  plugin_alias_names="$(sed -nE 's/^[[:space:]]*alias[[:space:]]+([^=[:space:]]+)=.*/\1/p' "$HOME/.config/op/plugins.sh" | paste -sd ',' -)"
  status "op plugin aliases" "${plugin_alias_names:-none}"
fi
exists_file "$HOME/.zshenv.local" ".zshenv.local"
exists_file "$HOME/.zshrc_custom/exports-local.zsh" "exports-local.zsh"
exists_file "$HOME/.1password/environments.toml" ".1password/environments.toml"

if command -v op >/dev/null 2>&1; then
  for plugin in gh openai codex sentry-cli todoist; do
    if op plugin list 2>/dev/null | awk -v p="$plugin" '$1 == p { found=1 } END { exit found ? 0 : 1 }'; then
      status "op plugin available:$plugin" "yes"
    else
      status "op plugin available:$plugin" "no"
    fi
  done
fi

if command -v ssh >/dev/null 2>&1; then
  effective_agent="$(ssh -G github.com 2>/dev/null | awk 'tolower($1) == "identityagent" { sub(/^[^[:space:]]+[[:space:]]+/, ""); print; exit }')"
  status "ssh github.com IdentityAgent" "$(printf "%s" "${effective_agent:-missing}" | redact_home)"
  gh_ssh_tmp="$(mktemp -t onepassword-dev-preflight-gh-ssh.XXXXXX 2>/dev/null || true)"
  if [[ -z "$gh_ssh_tmp" ]]; then
    status "ssh github.com auth" "skipped; temp file unavailable"
  elif ssh -o BatchMode=yes -o NumberOfPasswordPrompts=0 -o ConnectTimeout=5 -T git@github.com >"$gh_ssh_tmp" 2>&1; then
    status "ssh github.com auth" "unexpected success"
  elif grep -q "successfully authenticated" "$gh_ssh_tmp" 2>/dev/null; then
    status "ssh github.com auth" "ok"
  else
    status "ssh github.com auth" "unavailable"
  fi
  [[ -z "${gh_ssh_tmp:-}" ]] || rm -f "$gh_ssh_tmp"
fi

if command -v git >/dev/null 2>&1; then
  credential_helpers="$(git config --global --get-all credential.helper 2>/dev/null | paste -sd ',' -)"
  status "git credential.helper" "${credential_helpers:-missing}"
fi

if command -v gh >/dev/null 2>&1; then
  command_ok "gh auth status" gh auth status
  command_ok "gh api user" gh api user
  status "gh git_protocol" "$(gh config get git_protocol -h github.com 2>/dev/null || printf missing)"
else
  status "gh" "missing"
fi

env_present GH_TOKEN
env_present GITHUB_TOKEN

env_names=("${(@f)$(discover_env_names)}")
if (( ${#env_names[@]} > 0 )); then
  for name in "${env_names[@]}"; do
    env_present "$name"
  done
else
  status "env names" "none discovered"
fi
