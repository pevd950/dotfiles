#!/usr/bin/env bash
set -euo pipefail

echo "=== Starting yadm bootstrap ==="

setup_yadm_alternates() {
  # Run yadm alternates (only needed for yadm)
  echo "Setting up yadm alternates..."
  yadm alt
}

setup_code_user_dir() {
  # Create necessary directories
  mkdir -p "$HOME/.config/Code/User"
}

run_setup_script() {
  # Run the main setup script (shared with Codespaces)
  echo "Running main setup script..."
  if [[ -f "$HOME/setup.sh" ]]; then
    bash "$HOME/setup.sh"
  else
    echo "Warning: setup.sh not found in home directory"
  fi
}

setup_agent_skills() {
  echo "Setting up agent skills compatibility links..."
  local skills_root="$HOME/.agents/skills"
  local claude_dir="$HOME/.claude/skills"
  local legacy_root="$HOME/.config/agent-skills/skills"
  local codex_dir="${CODEX_HOME:-$HOME/.codex}/skills"
  local copilot_dir="$HOME/.copilot/skills"
  local skill_path name target link_dest provider_dir legacy_target

  mkdir -p "$claude_dir"

  for provider_dir in "$codex_dir" "$copilot_dir" "$claude_dir"; do
    [[ -d "$provider_dir" ]] || continue
    shopt -s nullglob
    for target in "$provider_dir"/*; do
      [[ -L "$target" ]] || continue
      link_dest=$(readlink "$target" || true)
      if [[ "$link_dest" == "$legacy_root"/* || "$link_dest" == "$skills_root"/* ]]; then
        echo "Removing obsolete provider skill link: $target"
        rm "$target"
      elif [[ ! -e "$target" ]]; then
        echo "Removing broken provider skill link: $target"
        rm "$target"
      fi
    done
    shopt -u nullglob
  done

  if [[ -d "$skills_root" ]]; then
    shopt -s nullglob
    for skill_path in "$skills_root"/* "$skills_root"/*/*; do
      [[ -d "$skill_path" ]] || continue
      [[ -f "$skill_path/SKILL.md" ]] || continue
      name=$(basename "$skill_path")
      target="$claude_dir/$name"
      legacy_target="$legacy_root/$name"
      if [[ -L "$target" ]]; then
        link_dest=$(readlink "$target" || true)
        if [[ "$link_dest" == "$skill_path" ]]; then
          continue
        elif [[ "$link_dest" == "$legacy_target" || ! -e "$target" ]]; then
          echo "Updating Claude skill link: $target"
          rm "$target"
        else
          echo "Skipping existing non-matching Claude skill path: $target"
          continue
        fi
      elif [[ -e "$target" ]]; then
        echo "Skipping existing non-matching Claude skill path: $target"
        continue
      fi
      ln -s "$skill_path" "$target"
    done
    shopt -u nullglob
  else
    echo "No skills found at $skills_root"
  fi
}

main() {
  setup_yadm_alternates
  setup_code_user_dir
  run_setup_script
  setup_agent_skills
}

main "$@"

echo "=== Bootstrap complete ==="
